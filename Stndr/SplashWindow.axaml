<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Stndr.SplashWindow"
        Width="520"
        Height="360"
        CanResize="False"
        WindowDecorations="None"
        WindowStartupLocation="CenterScreen"
        Background="#F8FBFF"
        Icon="/Assets/AppIcon.ico"
        ShowInTaskbar="False">
    <Border Background="#F8FBFF"
            BorderBrush="#00A6C8"
            BorderThickness="1">
        <Grid RowDefinitions="*,Auto,Auto"
              Margin="44">
            <Image Grid.Row="0"
                   Source="/Assets/AppIcon.png"
                   Stretch="Uniform"
                   MaxWidth="420"
                   MaxHeight="230"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

            <TextBlock Grid.Row="1"
                       Text="Powered by Sefaria.org"
                       FontSize="14"
                       Foreground="#102A43"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,18" />

            <ProgressBar Grid.Row="2"
                         Height="4"
                         Minimum="0"
                         Maximum="100"
                         IsIndeterminate="True"
                         Background="#DDEAF2"
                         Foreground="#00A6C8" />
        </Grid>
    </Border>
</Window>
