<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Stndr.SplashWindow"
        Width="520"
        Height="360"
        CanResize="False"
        WindowDecorations="None"
        WindowStartupLocation="CenterScreen"
        Background="#F8FBFF"
        Icon="/Assets/AppIcon.ico"
        ShowInTaskbar="False">
    <Border Background="#F8FBFF"
            BorderBrush="#00A6C8"
            BorderThickness="1">
        <Grid RowDefinitions="*,Auto,Auto"
              Margin="44">
            <Image Grid.Row="0"
                   Source="/Assets/AppIcon.png"
                   Stretch="Uniform"
                   MaxWidth="420"
                   MaxHeight="230"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center" />

            <TextBlock Grid.Row="1"
                       Text="Powered by Sefaria.org"
                       FontSize="14"
                       Foreground="#102A43"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,18" />

            <Border Grid.Row="2"
                    Height="4"
                    Background="#DDEAF2"
                    ClipToBounds="True">
                <Canvas x:Name="LoadingTrack">
                    <Border x:Name="LoadingPill"
                            Width="150"
                            Height="4"
                            Background="#00A6C8" />
                </Canvas>
            </Border>
        </Grid>
    </Border>
</Window>
