<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
        x:Class="Stndr.MainWindow"
        Title="Stndr"
        Icon="/Assets/AppIcon.ico"
        WindowState="Maximized">
    <Window.Styles>
        <Style Selector="TabControl#CenterTabs">
            <Setter Property="Background" Value="#D8E7FF" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style Selector="TabControl#CenterTabs TabItem">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="Button.tab-close-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="Button.tab-close-button:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="Button.tab-close-button:pressed">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.reader-list">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:pointerover">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:pressed">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:current">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:focus">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:selected">
            <Setter Property="Background" Value="#105AA9E6" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:selected:pointerover">
            <Setter Property="Background" Value="#105AA9E6" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:current /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:focus /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#105AA9E6" />
        </Style>

        <Style Selector="ListBox.reader-list ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#105AA9E6" />
        </Style>

        <Style Selector="Button.reader-nav-button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.reader-nav-button:pointerover">
            <Setter Property="Background" Value="#08000000" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>

        <Style Selector="Button.commentary-source-row">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#EAECF0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>

        <Style Selector="Button.commentary-source-row:pointerover">
            <Setter Property="Background" Value="#FCFCFD" />
            <Setter Property="BorderBrush" Value="#EAECF0" />
        </Style>

        <Style Selector="Button.commentary-source-row:pressed">
            <Setter Property="Background" Value="#F2F4F7" />
            <Setter Property="BorderBrush" Value="#EAECF0" />
        </Style>

        <Style Selector="Button.commentary-source-row.selected">
            <Setter Property="Background" Value="#F9FAFB" />
        </Style>
    </Window.Styles>

    <Grid x:Name="LayoutRoot"
          RowDefinitions="Auto,Auto,*"
          ColumnDefinitions="280,5,*,5,280">

        <Border Grid.Row="0"
                Grid.ColumnSpan="5"
                Padding="8"
                BorderThickness="0,0,0,1"
                BorderBrush="#22000000">
            <StackPanel Orientation="Horizontal"
                        Spacing="8">
                <Button Content="Library Manager" Click="OpenLibraryManagerClicked" />
                <Button Content="Advanced Search" Click="OpenAdvancedSearchClicked" />
                <Button Content="Settings" Click="OpenSettingsClicked" />
            </StackPanel>
        </Border>

        <Border x:Name="UpdateBanner"
                Grid.Row="1"
                Grid.ColumnSpan="5"
                IsVisible="False"
                Background="#E8F0FC"
                BorderThickness="0,0,0,1"
                BorderBrush="#22000000"
                Padding="8,6">
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Right"
                            Spacing="8">
                    <Button x:Name="UpdateBannerActionButton"
                            MinWidth="96"
                            Click="UpdateBannerActionClicked" />
                    <Button x:Name="UpdateBannerDismissButton"
                            Content="Later"
                            MinWidth="64"
                            Click="UpdateBannerDismissClicked" />
                </StackPanel>
                <TextBlock x:Name="UpdateBannerMessage"
                           Text="An update is available."
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Grid.Column="0"
                BorderThickness="0,0,1,0"
                BorderBrush="#22000000">
            <Grid RowDefinitions="Auto,*">
                <DockPanel Margin="6">
                    <Button
                            Content="☰"
                            Click="ToggleLeftPanel"
                            Width="28"
                            HorizontalAlignment="Left" />
                    <TextBlock x:Name="LeftPanelTitle"
                               Text="Library"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </DockPanel>

                <ScrollViewer x:Name="LeftPanelBody"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="6"
                                HorizontalAlignment="Stretch"
                                Spacing="8">
                        <Expander Header="Installed Books"
                                  IsExpanded="True"
                                  HorizontalAlignment="Stretch">
                            <TreeView x:Name="InstalledBooksTree"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="OnInstalledBookSelectionChanged" />
                        </Expander>

                        <Expander Header="Saved Searches"
                                  IsExpanded="True"
                                  HorizontalAlignment="Stretch">
                            <ListBox x:Name="SavedSearchesList"
                                     MinHeight="80"
                                     HorizontalAlignment="Stretch"
                                     SelectionChanged="OnSavedSearchSelectionChanged" />
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <GridSplitter x:Name="LeftSplitter"
                      Grid.Row="2"
                      Grid.Column="1"
                      Background="Transparent"
                      Width="5"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext" />

        <Grid Grid.Row="2"
              Grid.Column="2"
              Margin="8"
              RowDefinitions="Auto,*">
            <TabControl x:Name="CenterTabs"
                        Grid.Row="0" />
            <Grid x:Name="CenterTabContentHost"
                  Grid.Row="1"
                  Background="White" />
        </Grid>

        <GridSplitter x:Name="RightSplitter"
                      Grid.Row="2"
                      Grid.Column="3"
                      Background="Transparent"
                      Width="5"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext" />

        <Border Grid.Row="2"
                Grid.Column="4"
                BorderThickness="1,0,0,0"
                BorderBrush="#22000000">
            <Grid RowDefinitions="Auto,*">
                <DockPanel Margin="6">
                    <Button
                            Content="☰"
                            Click="ToggleRightPanel"
                            Width="28"
                            HorizontalAlignment="Left" />
                    <TextBlock x:Name="RightPanelTitle"
                               Text="Reader Tools"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                </DockPanel>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="RightPanelBody"
                                Margin="8"
                                HorizontalAlignment="Stretch"
                                Spacing="8">
                        <TextBlock Text="Open a text to see reader tools." TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
